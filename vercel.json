{
  "rewrites": [
    {
      "source": "/auth/:match*",
      "destination": "https://projet-de-fin-d-etudes.onrender.com/auth/:match*"
    },
    {
      "source": "/api/:match*",
      "destination": "https://projet-de-fin-d-etudes.onrender.com/api/:match*"
    },
    {
      "source": "/ws/:match*",
      "destination": "wss://projet-de-fin-d-etudes.onrender.com/ws/:match*"
    },
    {
      "source": "/:(.*)",
      "destination": "/index.html"
    }
  ]
}
